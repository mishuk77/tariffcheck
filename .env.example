# ===========================================
# TariffCheck Environment Variables
# ===========================================
# Copy this file to .env and fill in values
#
# IMPORTANT: Never commit .env to git.
# Use EAS Secrets for CI/CD: https://docs.expo.dev/build-reference/variables/

# Expo / EAS (required for CI/CD builds)
# Generate at: https://expo.dev/accounts/[your-username]/settings/access-tokens
EXPO_TOKEN=your_expo_token_here
